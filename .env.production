# Production env — коммитится в git (секретов нет, только публичные URL)
# Vite автоматически подхватывает этот файл при NODE_ENV=production (npm run build)

# Can be DEBUG, INFO, WARN, ERROR
VITE_LOG_LEVEL=WARN

# API проксируется через Caddy → gateway на относительных путях,
# поэтому хост не нужен — только путь.
VITE_AUTH_API_URL=/api/v1
VITE_CORE_API_URL=/api/v1
